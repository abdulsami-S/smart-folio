# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get this from: Atlas → Clusters → Connect
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sami_portfolio?retryWrites=true&w=majority

# JWT Secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_random_256_bit_string_here
REFRESH_SECRET=generate_a_different_random_256_bit_string_here

# Token Expiry
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Admin Credentials
ADMIN_USERNAME=sami
ADMIN_PASSWORD=change_this_to_your_password

# Frontend URL
CLIENT_URL=http://localhost:5173
